generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext, uuidOssp(map: "uuid-ossp")]
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum Role {
  SUPER_ADMIN
  TEACHER
  STUDENT
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  FILL_BLANK
  TRUE_FALSE
  MATCH_FOLLOWING
  MATRIX_MATCH
  DESCRIPTIVE
  VISUAL
}

enum UploadStatus {
  PENDING_UPLOAD
  UPLOADED
  PROCESSING
  READY_FOR_REVIEW
  APPROVED
  FAILED
}

enum OcrDraftStatus {
  PENDING_REVIEW
  EDITED
  APPROVED
  DISCARDED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

// Delivery channel for an institution-sent communication (the audit-log entity
// below). Distinct from NotificationChannel, which is the narrow in-app/email
// pair that powers the personal notification bell. Channels here are aspirational
// — actual SMS/Push/WhatsApp delivery is not wired yet; this records intent.
enum DeliveryChannel {
  EMAIL
  SMS
  PUSH
  WHATSAPP
  IN_APP
}

// Category of a sent communication, used to filter the history view.
enum CommunicationType {
  EXAM_ALERT
  REPORT_PUBLISHED
  ATTENDANCE_ALERT
  FEE_REMINDER
  CIRCULAR
  ANNOUNCEMENT
  GENERAL
}

// Delivery outcome recorded for the communication history / audit log.
enum CommunicationStatus {
  SENT
  FAILED
  SCHEDULED
  PARTIAL
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSED
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  GRADED
  FLAGGED
}

enum ViolationType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  COPY_ATTEMPT
  PASTE_ATTEMPT
  RIGHT_CLICK
  WINDOW_BLUR
  DEVTOOLS_OPEN
  NETWORK_DROP
}

enum TestMode {
  ONLINE
  OFFLINE_PRINT
}

// Separates the composition asset (PAPER) from the delivery asset (TEST).
// Papers stay status=DRAFT forever and cannot be published or assigned.
// Tests follow the existing DRAFT -> SCHEDULED -> LIVE -> CLOSED lifecycle.
// All pre-existing rows are TESTs (default).
enum ExamKind {
  PAPER
  TEST
}

// Lifecycle for the standalone QuestionPaper module (decoupled from Exam).
enum QuestionPaperStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Tenant {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  branches         Branch[]
  users            User[]
  students         Student[]
  classrooms       Classroom[]
  uploads          Upload[]
  ocrJobs          OcrJob[]
  ocrDrafts        OcrDraft[]
  ocrDraftFigures  OcrDraftFigure[]
  questions        Question[]
  questionOptions  QuestionOption[]
  notifications    Notification[]
  exams            Exam[]
  examSections     ExamSection[]
  examQuestions    ExamQuestion[]
  examAssignments  ExamAssignment[]
  examAttempts     ExamAttempt[]
  attemptAnswers   AttemptAnswer[]
  violations       Violation[]
  questionStats    QuestionStat[]
  topicReports     TopicReport[]
  programs         Program[]
  subjects         Subject[]
  topics           Topic[]
  chapters         Chapter[]
  questionPapers   QuestionPaper[]
  ocrBatches       OcrBatch[]
  communications   Communication[]

  @@map("tenants")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users      User[]
  students   Student[]
  classrooms Classroom[]
  exams      Exam[]
  questions  Question[]
  uploads    Upload[]

  @@index([tenantId])
  @@map("branches")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  tenantId     String     @map("tenant_id") @db.Uuid
  branchId     String?    @map("branch_id") @db.Uuid
  email        String     @db.Citext
  phone        String?
  passwordHash String     @map("password_hash")
  name         String
  role         Role
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  refreshTokens     RefreshToken[]
  studentProfile    Student?
  createdClassrooms Classroom[]    @relation("ClassroomCreator")
  uploads           Upload[]
  questions         Question[]
  notifications     Notification[]
  createdExams      Exam[]         @relation("ExamCreator")
  teacherSubjects   TeacherSubject[]
  ocrBatches        OcrBatch[]
  teacherClassrooms ClassroomTeacher[]
  sentCommunications Communication[]

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Student {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @map("tenant_id") @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  branchId        String?  @map("branch_id") @db.Uuid
  classLabel      String?  @map("class_label")
  rollNo          String?  @map("roll_no")
  parentContact   String?  @map("parent_contact")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch            Branch?             @relation(fields: [branchId], references: [id], onDelete: SetNull)
  classrooms        ClassroomStudent[]
  examAssignments   ExamAssignment[]
  examAttempts      ExamAttempt[]
  topicReports      TopicReport[]

  @@index([tenantId, branchId])
  @@map("students")
}

model Classroom {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  branchId  String   @map("branch_id") @db.Uuid
  name      String
  year      String?
  section   String?
  subject   String?
  createdBy String   @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  creator         User               @relation("ClassroomCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  students        ClassroomStudent[]
  teachers        ClassroomTeacher[]
  examAssignments ExamAssignment[]

  // A classroom is identified by name + academic year + section within a branch,
  // so the same class/year can have multiple sections (A, B, C, …). Only an exact
  // name+year+section duplicate is rejected.
  @@unique([tenantId, branchId, name, year, section])
  @@index([tenantId, branchId])
  @@map("classrooms")
}

model ClassroomStudent {
  classroomId String   @map("classroom_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([classroomId, studentId])
  @@map("classroom_students")
}

model ClassroomTeacher {
  classroomId String   @map("classroom_id") @db.Uuid
  teacherId   String   @map("teacher_id") @db.Uuid
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  classroom Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  teacher   User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@id([classroomId, teacherId])
  @@map("classroom_teachers")
}

model Upload {
  id            String       @id @default(uuid()) @db.Uuid
  tenantId      String       @map("tenant_id") @db.Uuid
  uploadedBy    String       @map("uploaded_by") @db.Uuid
  originalName  String       @map("original_name")
  mimeType      String       @map("mime_type")
  sizeBytes     BigInt?      @map("size_bytes")
  storageKey    String       @map("storage_key")
  status        UploadStatus @default(PENDING_UPLOAD)
  errorMessage  String?      @map("error_message")
  programId     String?      @map("program_id") @db.Uuid
  subjectId     String?      @map("subject_id") @db.Uuid
  // Upload-level OCR diagnostics: source type, page classifications, layout
  // issues. Populated by the parent OCR job; null for non-OCR uploads.
  // Shape: { sourceType: 'DIGITAL_PDF'|'SCANNED_PDF'|'HANDWRITTEN'|'MIXED',
  //          pageCount: number, hasLayoutIssues: boolean, notes?: string }
  ocrMeta       Json?        @map("ocr_meta")
  branchId      String?      @map("branch_id") @db.Uuid
  // Multi-file batch import (orchestration only — does NOT change the OCR
  // pipeline). batchId groups uploads imported together; batchOrder is the
  // upload's position in that batch (0-based). Both null for single-file
  // uploads, which behave exactly as before.
  batchId       String?      @map("batch_id") @db.Uuid
  batchOrder    Int?         @map("batch_order")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploader  User       @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  program   Program?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  subject   Subject?   @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  branch    Branch?    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  batch     OcrBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  ocrJob    OcrJob?
  questions Question[]

  @@index([tenantId, branchId])
  @@index([tenantId, uploadedBy])
  @@index([tenantId, status])
  @@index([tenantId, programId, subjectId])
  @@index([tenantId, batchId])
  @@map("uploads")
}

// Multi-file OCR import batch — a pure orchestration grouping over Uploads.
// Each upload still runs through the UNCHANGED single-file OCR pipeline one at a
// time; the batch only records that they were imported together so the review
// layer can show aggregate progress and continuous (batchSequence) numbering.
// No drafts/questions are owned here — those stay on the per-upload OcrJob.
model OcrBatch {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  createdBy  String   @map("created_by") @db.Uuid
  totalFiles Int      @map("total_files")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  uploads Upload[]

  @@index([tenantId])
  @@map("ocr_batches")
}

model OcrJob {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  uploadId           String    @unique @map("upload_id") @db.Uuid
  queuedAt           DateTime  @default(now()) @map("queued_at") @db.Timestamptz(6)
  startedAt          DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt         DateTime? @map("finished_at") @db.Timestamptz(6)
  overallConfidence  Decimal?  @map("overall_confidence") @db.Decimal(4, 3)
  errorMessage       String?   @map("error_message")
  rawOutput          Json?     @map("raw_output")
  providerUsed       String?   @map("provider_used") // 'paddle' | 'vision' | 'tesseract' | 'pdfjs'
  // Per-page classification — array of { pageNum, type, confidence, draftCount }
  // where type ∈ INSTRUCTION | QUESTION | ANSWER_KEY | OMR | UNKNOWN.
  pageMetadata       Json?     @map("page_metadata")
  // Per-page layout — array of { pageNum, layout, columnCount, confidence }
  // where layout ∈ SINGLE | TWO_COLUMN | MULTI_COLUMN | UNKNOWN.
  layoutMetadata     Json?     @map("layout_metadata")
  // Live progress for the parent OCR job — { processed: int, total: int, currentPage?: int }.
  progress           Json?     @map("progress")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  upload Upload     @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  drafts OcrDraft[]

  @@index([tenantId, uploadId])
  @@map("ocr_jobs")
}

model OcrDraft {
  id                  String         @id @default(uuid()) @db.Uuid
  tenantId            String         @map("tenant_id") @db.Uuid
  ocrJobId            String         @map("ocr_job_id") @db.Uuid
  position            Int
  text                String
  detectedType        QuestionType?  @map("detected_type")
  options             Json?
  confidence          Decimal?       @db.Decimal(4, 3)
  status              OcrDraftStatus @default(PENDING_REVIEW)
  approvedQuestionId  String?        @unique @map("approved_question_id") @db.Uuid
  figures             OcrDraftFigure[]
  // Source page traceability — which page in the original PDF/image this draft
  // came from. Null for legacy drafts created before per-page tracking.
  sourcePageNumber    Int?           @map("source_page_number")
  // For questions that span multiple pages (rare but real in NEET papers),
  // spanPageStart and spanPageEnd bracket the range. spanPageStart equals
  // sourcePageNumber when the question stays on one page.
  spanPageStart       Int?           @map("span_page_start")
  spanPageEnd         Int?           @map("span_page_end")
  // Optional solution/explanation block when the source paper includes one
  // (markers: "Solution:", "Explanation:", "Ans:" — separated from the stem).
  solutionText        String?        @map("solution_text")
  // Screenshot-first OCR: questionSnapshotKey is the R2 key of the cropped
  // question-region image (the Visual Question's source of truth). optionCount
  // is the number of answer slots detected on the crop (2..6); sourceCoordinates
  // is the bounding box on the source page { x0, y0, x1, y1 }.
  questionSnapshotKey String?        @map("question_snapshot_key")
  optionCount         Int?           @map("option_count")
  sourceCoordinates   Json?          @map("source_coordinates")
  // Segmentation: the detected question number at the top of this crop (e.g. 103)
  // and whether the crop is invalid (no number/stem/marker — diagram/footer/
  // option fragment). These come from the engine and drive the Question Navigator
  // (reliable count + missing/merged/invalid status) and answer-key mapping.
  questionNumber      Int?           @map("question_number")
  invalidCrop         Boolean?       @map("invalid_crop")
  // Answer-key import: a pre-filled correct answer mapped from an uploaded/typed
  // answer key ("1-A 2-C …"), so the teacher reviews exceptions instead of
  // hand-picking every answer. Shape: { source, raw, correctIndex?, correct? }.
  // Null until an answer key is imported for the draft's job.
  suggestedAnswer     Json?          @map("suggested_answer")
  // Bulk taxonomy: Program/Subject/Chapter/Topic + difficulty assigned once over
  // a whole OCR batch ("apply to all/selected") so the teacher doesn't configure
  // every question. Stored denormalized (no FK) — these are review-time defaults
  // the approve flow inherits unless the approver overrides them. Null until set.
  assignedProgramId   String?        @map("assigned_program_id") @db.Uuid
  assignedSubjectId   String?        @map("assigned_subject_id") @db.Uuid
  assignedTopicId     String?        @map("assigned_topic_id") @db.Uuid
  assignedChapterId   String?        @map("assigned_chapter_id") @db.Uuid
  assignedDifficulty  Difficulty?    @map("assigned_difficulty")
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ocrJob            OcrJob    @relation(fields: [ocrJobId], references: [id], onDelete: Cascade)
  approvedQuestion  Question? @relation(fields: [approvedQuestionId], references: [id], onDelete: SetNull)

  @@index([tenantId, ocrJobId])
  @@index([tenantId, status])
  @@map("ocr_drafts")
}

// OCR-detected visual asset (figure / table / circuit / chemistry structure)
// attached to a draft. Explicitly 1:many (draft -> many figures) so that real
// coaching-centre questions with multiple diagrams or image-based options work
// naturally. Stays empty until figure detection ships (Phase B); the table is
// defined now to lock the data-model contract in advance.
//
// When a draft is approved into a Question, the figure refs flow into
// Question.payload.imageRefs[] (formalized DTO landing with figure detection).
model OcrDraftFigure {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  draftId       String   @map("draft_id") @db.Uuid
  /// Position within the draft (stem / option-image / solution-image, etc.).
  figureIndex   Int      @map("figure_index")
  /// Storage key (R2/S3) - same Upload category as the snipping-tool uploads.
  storageKey    String   @map("storage_key")
  /// Pixel-coord box on the source page: { x, y, w, h, page }.
  boundingBox   Json     @map("bounding_box")
  /// Detected role: 'figure' | 'table' | 'option_image' | 'solution_image'.
  kind          String
  /// Optional caption / alt-text.
  caption       String?
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  draft  OcrDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([tenantId, draftId])
  @@map("ocr_draft_figures")
}

model Question {
  id              String       @id @default(uuid()) @db.Uuid
  tenantId        String       @map("tenant_id") @db.Uuid
  createdBy       String       @map("created_by") @db.Uuid
  sourceUploadId  String?      @map("source_upload_id") @db.Uuid
  type            QuestionType
  payload         Json
  programId       String?      @map("program_id") @db.Uuid
  subjectId       String?      @map("subject_id") @db.Uuid
  topicId         String?      @map("topic_id") @db.Uuid
  chapterId       String?      @map("chapter_id") @db.Uuid
  subject         String?      // denormalized for analytics rollups (TopicReport)
  topic           String?      // denormalized (leaf) for analytics rollups (TopicReport)
  chapter         String?      // denormalized (mid-level) for future chapter-level reporting
  difficulty      Difficulty   @default(MEDIUM)
  isActive        Boolean      @default(true) @map("is_active")
  branchId        String?      @map("branch_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator       User             @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  sourceUpload  Upload?          @relation(fields: [sourceUploadId], references: [id], onDelete: SetNull)
  programRef    Program?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  subjectRef    Subject?         @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  topicRef      Topic?           @relation(fields: [topicId], references: [id], onDelete: SetNull)
  chapterRef    Chapter?         @relation(fields: [chapterId], references: [id], onDelete: SetNull)
  branch        Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  options            QuestionOption[]
  sourceDraft        OcrDraft?
  examQuestions      ExamQuestion[]
  questionStat       QuestionStat?
  questionPaperLinks QuestionPaperQuestion[]

  @@index([tenantId, branchId])
  @@index([tenantId, subject, topic])
  @@index([tenantId, programId, subjectId])
  @@index([tenantId, chapterId])
  @@index([tenantId, type])
  @@index([tenantId, createdBy])
  @@map("questions")
}

model QuestionOption {
  id         String  @id @default(uuid()) @db.Uuid
  tenantId   String  @map("tenant_id") @db.Uuid
  questionId String  @map("question_id") @db.Uuid
  label      String
  isCorrect  Boolean @default(false) @map("is_correct")
  position   Int

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([tenantId, questionId])
  @@map("question_options")
}

model Notification {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  recipientUserId String              @map("recipient_user_id") @db.Uuid
  channel         NotificationChannel
  subject         String
  body            String
  readAt          DateTime?           @map("read_at") @db.Timestamptz(6)
  sentAt          DateTime?           @map("sent_at") @db.Timestamptz(6)
  failedAt        DateTime?           @map("failed_at") @db.Timestamptz(6)
  attemptCount    Int                 @default(0) @map("attempt_count")
  errorMessage    String?             @map("error_message")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient User   @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, recipientUserId, readAt])
  @@index([channel, sentAt, failedAt])
  @@map("notifications")
}

// Communication history / audit log. One row per broadcast an institution sends
// to a cohort (students, parents, staff) — the source for the admin-facing
// "communication history center". This is deliberately SEPARATE from the
// per-recipient Notification feed above: a Communication is the campaign record
// (title, type, channel, audience size, sender, outcome), not an inbox item.
// Recipient detail is summarised as counts (recipientCount / deliveredCount /
// failedCount) rather than per-user rows; a dedicated recipients table can be
// added later if individual delivery tracking is needed.
model Communication {
  id              String              @id @default(uuid()) @db.Uuid
  tenantId        String              @map("tenant_id") @db.Uuid
  title           String
  body            String
  type            CommunicationType
  channel         DeliveryChannel
  status          CommunicationStatus @default(SENT)
  // Free-text descriptor of who it went to, e.g. "Class 10 Students",
  // "All Parents". Kept as a label for now; structured targeting can come later.
  audience        String?
  recipientCount  Int                 @default(0) @map("recipient_count")
  deliveredCount  Int                 @default(0) @map("delivered_count")
  failedCount     Int                 @default(0) @map("failed_count")
  // Sender — nullable so system-generated communications can have no human owner.
  // sentByName is denormalised so the history row survives the user being deleted.
  sentById        String?             @map("sent_by_id") @db.Uuid
  sentByName      String?             @map("sent_by_name")
  scheduledAt     DateTime?           @map("scheduled_at") @db.Timestamptz(6)
  sentAt          DateTime?           @map("sent_at") @db.Timestamptz(6)
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sentBy User?  @relation(fields: [sentById], references: [id], onDelete: SetNull)

  @@index([tenantId, sentAt])
  @@index([tenantId, type])
  @@index([tenantId, channel])
  @@index([tenantId, status])
  @@map("communications")
}

// ===== Phase 3 =====

model Exam {
  id                     String     @id @default(uuid()) @db.Uuid
  tenantId               String     @map("tenant_id") @db.Uuid
  createdBy              String     @map("created_by") @db.Uuid
  title                  String
  description            String?
  durationSeconds        Int        @map("duration_seconds")
  totalMarks             Decimal    @default(0) @map("total_marks") @db.Decimal(8, 2)
  defaultNegativeMarks   Decimal    @default(0) @map("default_negative_marks") @db.Decimal(5, 2)
  randomizeQuestions     Boolean    @default(false) @map("randomize_questions")
  randomizeOptions       Boolean    @default(false) @map("randomize_options")
  kind                   ExamKind   @default(TEST)
  status                 ExamStatus @default(DRAFT)
  opensAt                DateTime?  @map("opens_at") @db.Timestamptz(6)
  closesAt               DateTime?  @map("closes_at") @db.Timestamptz(6)
  testMode               TestMode   @default(ONLINE) @map("test_mode")
  publishedAt            DateTime?  @map("published_at") @db.Timestamptz(6)
  antiCheatConfig        Json       @default("{}") @map("anti_cheat_config")
  programId              String?    @map("program_id") @db.Uuid
  subjectId              String?    @map("subject_id") @db.Uuid
  branchId               String?    @map("branch_id") @db.Uuid
  // Provenance: the QuestionPaper this exam was snapshotted from (if any).
  // The exam owns its own copied ExamQuestion rows, so deleting/editing the
  // paper never changes this exam (SetNull on paper delete).
  sourcePaperId          String?    @map("source_paper_id") @db.Uuid
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator      User              @relation("ExamCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  program      Program?          @relation(fields: [programId], references: [id], onDelete: SetNull)
  subject      Subject?          @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  branch       Branch?           @relation(fields: [branchId], references: [id], onDelete: SetNull)
  sourcePaper  QuestionPaper?    @relation(fields: [sourcePaperId], references: [id], onDelete: SetNull)
  sections     ExamSection[]
  questions    ExamQuestion[]
  assignments  ExamAssignment[]
  attempts     ExamAttempt[]

  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([tenantId, createdBy])
  @@index([tenantId, programId, subjectId])
  @@index([tenantId, kind, status])
  @@map("exams")
}

model ExamSection {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  examId            String   @map("exam_id") @db.Uuid
  name              String
  position          Int
  timeLimitSeconds  Int?     @map("time_limit_seconds")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam      Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions ExamQuestion[]

  @@unique([examId, position])
  @@index([tenantId, examId])
  @@map("exam_sections")
}

model ExamQuestion {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  examId         String   @map("exam_id") @db.Uuid
  sectionId      String?  @map("section_id") @db.Uuid
  questionId     String   @map("question_id") @db.Uuid
  position       Int
  marks          Decimal  @db.Decimal(5, 2)
  negativeMarks  Decimal  @default(0) @map("negative_marks") @db.Decimal(5, 2)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam     Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  section  ExamSection?    @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  AttemptAnswer[]

  @@unique([examId, questionId])
  @@index([tenantId, examId, position])
  @@map("exam_questions")
}

model ExamAssignment {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  examId      String   @map("exam_id") @db.Uuid
  classroomId String?  @map("classroom_id") @db.Uuid
  studentId   String?  @map("student_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam      Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  classroom Classroom? @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  student   Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tenantId, examId])
  @@map("exam_assignments")
}

// Standalone, reusable academic asset composed from the Question Bank. Fully
// decoupled from Exam: papers have their own lifecycle (DRAFT/PUBLISHED/ARCHIVED)
// and are SNAPSHOTTED into an Exam at exam-creation time (see Exam.sourcePaperId),
// so later paper edits never alter historical exams and vice-versa.
model QuestionPaper {
  id                   String              @id @default(uuid()) @db.Uuid
  tenantId             String              @map("tenant_id") @db.Uuid
  branchId             String?             @map("branch_id") @db.Uuid
  createdBy            String              @map("created_by") @db.Uuid
  title                String
  description          String?
  programId            String?             @map("program_id") @db.Uuid
  subjectId            String?             @map("subject_id") @db.Uuid
  durationSeconds      Int                 @map("duration_seconds")
  defaultNegativeMarks Decimal             @default(0) @map("default_negative_marks") @db.Decimal(5, 2)
  totalMarks           Decimal             @default(0) @map("total_marks") @db.Decimal(8, 2)
  status               QuestionPaperStatus @default(DRAFT)
  archivedAt           DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions QuestionPaperQuestion[]
  exams     Exam[]

  @@index([tenantId, branchId])
  @@index([tenantId, status])
  @@index([tenantId, createdBy])
  @@map("question_papers")
}

model QuestionPaperQuestion {
  id            String  @id @default(uuid()) @db.Uuid
  paperId       String  @map("paper_id") @db.Uuid
  questionId    String  @map("question_id") @db.Uuid
  position      Int
  marks         Decimal @default(1) @db.Decimal(6, 2)
  negativeMarks Decimal @default(0) @map("negative_marks") @db.Decimal(5, 2)

  paper    QuestionPaper @relation(fields: [paperId], references: [id], onDelete: Cascade)
  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([paperId, questionId])
  @@index([paperId])
  @@map("question_paper_questions")
}

model ExamAttempt {
  id                      String        @id @default(uuid()) @db.Uuid
  tenantId                String        @map("tenant_id") @db.Uuid
  examId                  String        @map("exam_id") @db.Uuid
  studentId               String        @map("student_id") @db.Uuid
  status                  AttemptStatus @default(NOT_STARTED)
  startedAt               DateTime?     @map("started_at") @db.Timestamptz(6)
  submittedAt             DateTime?     @map("submitted_at") @db.Timestamptz(6)
  gradedAt                DateTime?     @map("graded_at") @db.Timestamptz(6)
  timeRemainingSeconds    Int?          @map("time_remaining_seconds")
  score                   Decimal?      @db.Decimal(8, 2)
  autoSubmitted           Boolean       @default(false) @map("auto_submitted")
  questionOrderSeed       BigInt        @map("question_order_seed")
  violationCount          Int           @default(0) @map("violation_count")
  descriptivePending      Boolean       @default(false) @map("descriptive_pending")
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  exam       Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student    Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers    AttemptAnswer[]
  violations Violation[]

  @@unique([examId, studentId])
  @@index([tenantId, studentId, status])
  @@index([tenantId, examId, status])
  @@map("exam_attempts")
}

model AttemptAnswer {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  attemptId           String   @map("attempt_id") @db.Uuid
  examQuestionId      String   @map("exam_question_id") @db.Uuid
  answerPayload       Json?    @map("answer_payload")
  isCorrect           Boolean? @map("is_correct")
  marksAwarded        Decimal? @map("marks_awarded") @db.Decimal(5, 2)
  timeSpentSeconds    Int      @default(0) @map("time_spent_seconds")
  isFlaggedByStudent  Boolean  @default(false) @map("is_flagged_by_student")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attempt      ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  examQuestion ExamQuestion @relation(fields: [examQuestionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, examQuestionId])
  @@index([tenantId, attemptId])
  @@map("attempt_answers")
}

model Violation {
  id              String        @id @default(uuid()) @db.Uuid
  tenantId        String        @map("tenant_id") @db.Uuid
  attemptId       String        @map("attempt_id") @db.Uuid
  type            ViolationType
  detail          Json?
  clientTimestamp DateTime      @map("client_timestamp") @db.Timestamptz(6)
  serverTimestamp DateTime      @default(now()) @map("server_timestamp") @db.Timestamptz(6)

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  attempt ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@index([tenantId, attemptId, serverTimestamp])
  @@map("violations")
}

model QuestionStat {
  questionId         String   @id @map("question_id") @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  totalAttempts      Int      @default(0) @map("total_attempts")
  correctAttempts    Int      @default(0) @map("correct_attempts")
  avgTimeSeconds     Decimal  @default(0) @map("avg_time_seconds") @db.Decimal(8, 2)
  difficultyScore    Decimal? @map("difficulty_score") @db.Decimal(4, 3)
  lastRecomputedAt   DateTime @default(now()) @map("last_recomputed_at") @db.Timestamptz(6)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("question_stats")
}

model TopicReport {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  studentId         String   @map("student_id") @db.Uuid
  subject           String
  topic             String
  attemptsCount     Int      @default(0) @map("attempts_count")
  correctCount      Int      @default(0) @map("correct_count")
  scorePercent      Decimal  @default(0) @map("score_percent") @db.Decimal(5, 2)
  isWeak            Boolean  @default(false) @map("is_weak")
  lastRecomputedAt  DateTime @default(now()) @map("last_recomputed_at") @db.Timestamptz(6)

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, topic])
  @@index([tenantId, studentId, isWeak])
  @@map("topic_reports")
}

// ===== Coaching-centre taxonomy: Program → Subject → Chapter → Topic =====

model Program {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  code      String   // 'FOUNDATION' | 'NEET' | 'IIT_JEE' | 'JEE_ADVANCED' (extensible per tenant)
  name      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subjects  Subject[]
  questions Question[]
  exams     Exam[]
  uploads   Upload[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("programs")
}

model Subject {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  programId String   @map("program_id") @db.Uuid
  name      String   // 'Physics', 'Chemistry', etc.
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  program   Program          @relation(fields: [programId], references: [id], onDelete: Cascade)
  chapters  Chapter[]
  teachers  TeacherSubject[]
  questions Question[]
  exams     Exam[]
  uploads   Upload[]

  @@unique([tenantId, programId, name])
  @@index([tenantId, programId])
  @@map("subjects")
}

// Chapter is the broad mid-level (child of Subject), Topic is the leaf (child of
// Chapter): Subject → Chapter → Topic.
model Chapter {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subject   Subject    @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics    Topic[]
  questions Question[]

  @@unique([tenantId, subjectId, name])
  @@index([tenantId, subjectId])
  @@map("chapters")
}

model Topic {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  chapterId String   @map("chapter_id") @db.Uuid
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chapter   Chapter    @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  questions Question[]

  @@unique([tenantId, chapterId, name])
  @@index([tenantId, chapterId])
  @@map("topics")
}

model TeacherSubject {
  userId    String   @map("user_id") @db.Uuid
  subjectId String   @map("subject_id") @db.Uuid
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([userId, subjectId])
  @@index([subjectId])
  @@map("teacher_subjects")
}
