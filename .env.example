# --- App ---
NODE_ENV=development
PORT=3000
# Comma-separated origins. Empty in production = no cross-origin requests allowed.
CORS_ORIGINS=http://localhost:5173

# --- Database ---
# Used by both Prisma and the API container. When running via docker-compose,
# host is "db". When running locally against compose's exposed port, use localhost:5433.
DATABASE_URL=postgresql://skolaris:skolaris@localhost:5434/skolaris?schema=public

# --- Auth ---
JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-me-with-another-long-random-string
JWT_REFRESH_TTL=7d

# --- Seed (used by prisma/seed.ts only) ---
SEED_TENANT_NAME=Acme Academy
SEED_TENANT_SLUG=acme
SEED_SUPER_ADMIN_EMAIL=admin@acme.test
SEED_SUPER_ADMIN_PASSWORD=Admin123!
SEED_TEACHER_EMAIL=teacher@acme.test
SEED_TEACHER_PASSWORD=Teacher123!
SEED_STUDENT_EMAIL_1=student1@acme.test
SEED_STUDENT_EMAIL_2=student2@acme.test
SEED_STUDENT_PASSWORD=Student123!

# --- Phase 2: Queue (Redis) ---
# OCR dispatch backend:
#   inline (default) → OCR runs IN-PROCESS, no Redis/BullMQ. Removes Redis as a
#                      deployment dependency for OCR (upload still acks instantly
#                      as PROCESSING; extraction runs async → READY_FOR_REVIEW).
#                      Trade-off: no cross-restart durability / auto-retry — a job
#                      lost to a restart is recovered by StuckUploadsCron (UI Retry).
#   redis            → OCR is enqueued to BullMQ and drained by a worker
#                      (WORKER_MODE=both/worker or an external ocr:real worker).
#                      Requires REDIS_URL. Flip here to re-enable; no code change.
QUEUE_DRIVER=inline
# REDIS_URL is REQUIRED only when QUEUE_DRIVER=redis. (Analytics + notifications
# still use BullMQ until Stage 2; they fall back to localhost and never block boot.)
REDIS_URL=redis://localhost:6380
OCR_QUEUE_NAME=ocr.extract

# --- Handwriting OCR fallback (OPTIONAL, default OFF == today's pipeline) ---
# When false (or unset) the Node/Tesseract pipeline handles everything and none
# of the routing/queue code below runs. Set to true AND run the Python
# handwriting microservice (Phase 2) to enable the fallback.
HANDWRITING_OCR_ENABLED=false
# Shadow mode: when enabled=true AND shadow=true, the classifier RUNS and LOGS
# its decision ([ocr-routing] ...) but does NOT route — Node still posts. Use it
# to validate routing on real uploads before enabling live routing.
HANDWRITING_OCR_SHADOW=false
HW_OCR_QUEUE_NAME=ocr.handwriting
# Dispatch mode for routed jobs: 'queue' (default, BullMQ — needs the Python
# consumer) or 'http' (synchronous POST to HANDWRITING_OCR_URL/ocr/extract —
# no second consumer, but the API process waits on the call).
HW_OCR_DISPATCH=queue
HANDWRITING_OCR_URL=
HANDWRITING_OCR_MIN_CONFIDENCE=0.7
HANDWRITING_OCR_TIMEOUT_MS=120000
# Inline-HTTP circuit breaker: open after N consecutive failures, retry after cooldown.
HW_OCR_BREAKER_THRESHOLD=3
HW_OCR_BREAKER_COOLDOWN_MS=30000
# Stuck-upload cutoff (default 5 min); raise if handwriting OCR is slow.
OCR_STUCK_CUTOFF_MS=300000
# Routing thresholds (only used when HANDWRITING_OCR_ENABLED=true; all optional).
OCR_ROUTE_CONFIDENCE_THRESHOLD=0.70
OCR_ROUTE_SCORE_THRESHOLD=0.50
OCR_ROUTE_CHARS_PER_PAGE=80
# Score weights [conf,lowWordRatio,medianWord,charsPerPage,alphaNoise,nonDict] + biases.
# Zero the last two weights for non-English tenants. Tune via `npm run ocr:calibrate`.
# OCR_ROUTE_WEIGHTS=0.30,0.20,0.15,0.15,0.10,0.10
# OCR_ROUTE_ANSWERSHEET_BIAS=0.10
# OCR_ROUTE_SCANLIKELY_BIAS=0.10
# Stage-1 PDF text-layer probe: >= chars/page ⇒ MACHINE_TEXT (force Node); < floor ⇒ scan-likely.
OCR_PRE_PROBE_PAGES=3
OCR_PRE_TEXTLAYER_CHARS_PER_PAGE=100
OCR_PRE_TEXTLAYER_FLOOR=10
# OCR_PRE_ANSWERSHEET_HINTS=answer-sheet,answersheet,/answers/,handwritten

# --- Phase 2: OCR callback ---
# Shared HMAC secret between this backend and the OCR microservice.
OCR_CALLBACK_SECRET=replace-me-with-a-long-random-string
OCR_SERVICE_BASE_URL=http://localhost:8000

# --- Phase 2: Object storage (S3/R2-only) ---
# SKOLARIS uses the S3 adapter exclusively. Cloudflare R2 is the canonical
# production backend; AWS S3 and MinIO (dev) use the same adapter. Leave
# STORAGE_PROVIDER unset or =s3 (any other value fails fast at boot).
STORAGE_PROVIDER=s3

AWS_S3_BUCKET=skolaris-uploads
AWS_REGION=auto                # Cloudflare R2: auto | real AWS: e.g. us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT — custom endpoint (REQUIRED for R2/MinIO; blank = real AWS).
#   Cloudflare R2: https://<accountid>.r2.cloudflarestorage.com
#   MinIO (dev):   http://localhost:9000  (or http://minio:9000 inside docker)
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_ENDPOINT — browser-reachable endpoint used to SIGN upload URLs, when
# it differs from S3_ENDPOINT (e.g. MinIO in docker: internal http://minio:9000,
# browser http://localhost:9000). Blank = same as S3_ENDPOINT. Not needed for R2.
S3_PUBLIC_ENDPOINT=
S3_FORCE_PATH_STYLE=true        # recommended for R2 + MinIO
#
# Reads on the private R2/S3 bucket are served by the backend read-proxy
# (GET /api/storage/v1/b/<bucket>/o/<key>?alt=media), so the frontend keeps its
# existing read URLs unchanged. Point the read hosts at the API origin:
#   frontend VITE_GCS_PUBLIC_HOST=http://localhost:3000/api   (image rendering)
#   STORAGE_READ_BASE_URL=http://localhost:3000/api           (standalone OCR worker only)
# The in-process OCR consumer (WORKER_MODE=both/worker) reads bytes directly via
# the adapter and needs NO read-host env. For Cloudflare R2 in prod, point these
# at your API origin (or a CDN/Worker proxy fronting it).
STORAGE_READ_BASE_URL=http://localhost:3000/api

# --- Phase 3: Workers ---
ANALYTICS_QUEUE_NAME=analytics.aggregate
NOTIFICATIONS_QUEUE_NAME=notifications.dispatch

# OCR consumer topology:
#   api    (default) → API only; an EXTERNAL worker drains the OCR queue
#                      (npm run ocr:real / docker ocr-mock). Unchanged behaviour.
#   both             → single service runs API + in-process OCR consumer
#                      (one `npm run start:prod`). Simplest deploy; OCR shares
#                      the API process (fine for low/medium PDF volume).
#   worker           → OCR consumer only, no HTTP listener (same image, scaled apart).
# Pick exactly ONE consumer: do NOT run a standalone ocr:real worker while an
# API instance is in 'both' mode against the same Redis.
WORKER_MODE=api

# --- Phase 3: Email (mailhog in dev: SMTP_HOST=localhost SMTP_PORT=1026) ---
SMTP_HOST=localhost
SMTP_PORT=1026
SMTP_FROM=no-reply@skolaris.local
SMTP_USER=
SMTP_PASS=

# Upload limits
UPLOAD_MAX_BYTES=26214400      # 25 MiB
UPLOAD_URL_TTL_SECONDS=900     # 15 minutes
